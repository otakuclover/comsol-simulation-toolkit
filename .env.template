# ============================================================================
# COMSOL Simulation Toolkit - Environment Configuration Template
# ============================================================================
#
# Copy this file to .env in your project root and customize the paths.
# The toolkit will auto-detect COMSOL if these are not set.
#
# Priority: Function args > Environment vars > .env file > Auto-detection
# ============================================================================

# ----------------------------------------------------------------------------
# COMSOL Installation (auto-detected if not set)
# ----------------------------------------------------------------------------

# Windows example:
# COMSOL_ROOT=C:/Program Files/COMSOL/COMSOL62/Multiphysics

# Linux example:
# COMSOL_ROOT=/usr/local/comsol62/multiphysics

# macOS example:
# COMSOL_ROOT=/Applications/COMSOL62/Multiphysics.app

# ----------------------------------------------------------------------------
# Temporary Files (defaults to system temp if not set)
# ----------------------------------------------------------------------------

# Windows example:
# COMSOL_TEMP_DIR=D:/comsol_tmp

# Linux example (fast local disk):
# COMSOL_TEMP_DIR=/scratch/comsol_tmp

# Linux example (RAM disk, for small models):
# COMSOL_TEMP_DIR=/tmp/comsol_tmp

# macOS example:
# COMSOL_TEMP_DIR=/tmp/comsol_tmp

# ----------------------------------------------------------------------------
# Project Paths (optional, defaults to current directory)
# ----------------------------------------------------------------------------

# Project root directory
# SIMULATION_PROJECT_DIR=/path/to/project

# Results output directory
# SIMULATION_RESULTS_DIR=/path/to/results

# ----------------------------------------------------------------------------
# Performance Settings
# ----------------------------------------------------------------------------

# Maximum parallel workers for parametric sweeps
# (default: CPU count, limited by license availability)
# COMSOL_MAX_WORKERS=4

# Java heap size for large models (optional, COMSOL default is usually fine)
# COMSOL_JVM_ARGS=-Xmx16G

# ----------------------------------------------------------------------------
# License Settings (usually auto-detected from COMSOL installation)
# ----------------------------------------------------------------------------

# License file path (for floating licenses, optional)
# COMSOL_LICENSE_FILE=/path/to/license.dat

# License server (for network licenses, optional)
# COMSOL_LICENSE_SERVER=27000@license-server.example.com

# ----------------------------------------------------------------------------
# Advanced Settings (rarely needed)
# ----------------------------------------------------------------------------

# Disable graphics for headless mode (HPC clusters)
# COMSOL_GRAPHICS=off

# Custom COMSOL JRE path (auto-detected from COMSOL_ROOT if not set)
# JAVA_HOME=/usr/local/comsol62/multiphysics/java/glnxa64/jre

# Logging level (DEBUG, INFO, WARNING, ERROR)
# COMSOL_TOOLKIT_LOG_LEVEL=INFO

# ============================================================================
# Platform-Specific Examples
# ============================================================================

# --- Windows Workstation ---
# COMSOL_ROOT=C:/Program Files/COMSOL/COMSOL62/Multiphysics
# COMSOL_TEMP_DIR=D:/comsol_tmp
# SIMULATION_PROJECT_DIR=D:/projects/my_sim
# SIMULATION_RESULTS_DIR=D:/projects/my_sim/results
# COMSOL_MAX_WORKERS=4

# --- Linux HPC Cluster ---
# COMSOL_ROOT=/opt/comsol62/multiphysics
# COMSOL_TEMP_DIR=/scratch/$USER/comsol_tmp
# SIMULATION_PROJECT_DIR=/home/$USER/projects/my_sim
# SIMULATION_RESULTS_DIR=/gpfs/results/my_sim
# COMSOL_MAX_WORKERS=16
# COMSOL_GRAPHICS=off

# --- macOS Laptop ---
# COMSOL_ROOT=/Applications/COMSOL62/Multiphysics.app
# COMSOL_TEMP_DIR=/tmp/comsol_tmp
# SIMULATION_PROJECT_DIR=/Users/$USER/projects/my_sim
# SIMULATION_RESULTS_DIR=/Users/$USER/projects/my_sim/results
# COMSOL_MAX_WORKERS=2
